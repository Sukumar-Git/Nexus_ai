{
  "manifest_version": 3,
  "name": "Nexus AI Companion",
  "version": "1.0.0",
  "description": "Chrome browser companion that reads active tabs, summarizes content, captures memory feeds, and provides smart resources.",
  "permissions": [
    "activeTab",
    "sidePanel",
    "storage",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open Nexus Companion",
    "default_popup": "popup.html"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
